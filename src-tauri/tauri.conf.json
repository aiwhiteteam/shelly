{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Shelly",
  "version": "1.0.0",
  "identifier": "app.shelly.dev",
  "build": {
    "frontendDist": "../dist/renderer",
    "beforeBuildCommand": "npm run build:frontend",
    "beforeDevCommand": ""
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Shelly",
        "width": 520,
        "height": 180,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "center": true,
        "y": 0,
        "visible": true,
        "shadow": false,
        "dragDropEnabled": false,
        "visibleOnAllWorkspaces": true
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": "default-src 'self' ipc: asset: http://ipc.localhost; style-src 'self' 'unsafe-inline'; font-src 'self'; script-src 'self' 'unsafe-eval' ipc: asset: http://ipc.localhost"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/aiwhiteteam/shelly/releases/latest/download/latest.json"
      ],
      "pubkey": "REPLACE_WITH_YOUR_PUBLIC_KEY"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
